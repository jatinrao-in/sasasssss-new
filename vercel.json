{
  "version": 2,
  "builds": [
    {
      "src": "admin-panel/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "team-member-pwa/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/admin", "headers": { "Location": "/admin/" }, "status": 308 },
    { "src": "/admin/assets/(.*)", "dest": "/admin-panel/assets/$1" },
    { "src": "/admin/(.*\\..*)", "dest": "/admin-panel/$1" },
    { "src": "/admin/(.*)", "dest": "/admin-panel/index.html" },
    { "src": "/((?!api/).+\\..*)", "dest": "/team-member-pwa/$1" },
    { "src": "/((?!api/)[^.]*)", "dest": "/team-member-pwa/index.html" }
  ],
  "crons": [
    { "path": "/api/cron/daily-tasks", "schedule": "30 2 * * *" },
    { "path": "/api/cron/send-reminders?slot=morning", "schedule": "30 1 * * *" },
    { "path": "/api/cron/send-reminders?slot=evening", "schedule": "30 13 * * *" }
  ]
}
