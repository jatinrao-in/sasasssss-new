# Vercel Backend — Environment Variables
# Copy this to .env.local for local testing with `vercel dev`
# Set all of these in: Vercel Dashboard → Project → Settings → Environment Variables

# ── Firebase Service Account ─────────────────────────────────────────────────
# Get from: Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=saya-industrial
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-XXXX@saya-industrial.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY_ID=your_key_id_here
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_ID=your_client_id_here

# ── MSG91 WhatsApp ────────────────────────────────────────────────────────────
MSG91_AUTH_KEY=485100A0EfaD5vBb8469ea3a72P1
MSG91_INTEGRATED_NUMBER=919081772047
# The name of your approved generic/freeform MSG91 template (for plain-text messages)
MSG91_FREEFORM_TEMPLATE=generic_notification

# ── Security ──────────────────────────────────────────────────────────────────
# Generate a random secret: openssl rand -hex 32
# This SAME value goes in: Vercel env vars AND GitHub repo secrets (as CRON_SECRET)
VERCEL_API_SECRET=generate_a_random_32char_secret_here
CRON_SECRET=generate_a_random_32char_secret_here

# ── Company ───────────────────────────────────────────────────────────────────
APP_COMPANY_NAME=Saya Industrial Solutions
