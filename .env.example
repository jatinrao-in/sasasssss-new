VITE_FIREBASE_API_KEY=your_public_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_public_messaging_sender_id
VITE_FIREBASE_APP_ID=your_public_web_app_id
VITE_FIREBASE_VAPID_KEY=your_public_web_push_vapid_key
VITE_API_BASE_URL=
VITE_BACKEND_URL=
VITE_ADMIN_URL=
VITE_PWA_URL=
CORS_ALLOWED_ORIGINS=

FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# Local .env files can keep the private key on one line with escaped \n characters.
# In the Vercel dashboard, paste the same key as a real multiline PEM and redeploy.
FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n
GEMINI_API_KEY=your_server_side_gemini_key
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_INTEGRATED_NUMBER=your_msg91_integrated_number
CRON_SECRET=generate_a_long_random_secret
