rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function isAssignedTo() {
      return isAuthenticated() && resource.data.assignedTo == request.auth.uid;
    }

    match /users/{uid} {
      allow read, write: if isAdmin();
      allow read: if isOwner(uid);
      allow update: if isOwner(uid)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'fcmToken',
          'fcmTokenUpdatedAt'
        ]);
    }

    match /projects/{projectId} {
      allow read, write, delete: if isAdmin();
      allow read: if isAuthenticated();
    }

    match /tasks/{taskId} {
      allow read, write, delete: if isAdmin();
      allow read: if isAssignedTo();
      allow update: if isAssignedTo()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'completionPercent',
          'status',
          'updatedAt'
        ]);
    }

    match /expenses/{expenseId} {
      allow read, write, delete: if isAdmin();
      allow create: if isAuthenticated()
        && request.resource.data.assignedTo == request.auth.uid;
      allow read: if isAuthenticated()
        && resource.data.assignedTo == request.auth.uid;
    }

    match /enquiries/{enquiryId} {
      allow read, write, delete: if isAdmin();
      allow read: if isAssignedTo();
      allow update: if isAssignedTo()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'updatedAt'
        ]);
    }

    match /followups/{followupId} {
      allow read, write, delete: if isAdmin();
      allow read: if isAssignedTo();
      allow update: if isAssignedTo()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'nextFollowupDate',
          'updatedAt'
        ]);
    }

    match /payments/{paymentId} {
      allow read, write, delete: if isAdmin();
      allow read: if isAssignedTo();
      allow update: if isAssignedTo()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'paymentStatus',
          'remarks',
          'partialPayments',
          'totalPaid',
          'netPending',
          'updatedAt'
        ]);
    }

    match /outgoing_payments/{id} {
      allow read, write, delete: if isAdmin();
      allow read: if isAssignedTo();
    }

    match /rgp/{rgpId} {
      allow read, write, delete: if isAdmin();
      allow read: if isAssignedTo();
    }

    match /salary/{uid}/months/{month} {
      allow read, write, delete: if isAdmin();
      allow read: if isOwner(uid);
    }

    match /tools/{toolId} {
      allow read, write, delete: if isAdmin();
      allow read: if isAssignedTo();
    }

    match /notifications/{uid}/items/{notifId} {
      allow write: if isAdmin();
      allow read, update: if isOwner(uid);
      allow delete: if isOwner(uid);
    }

    match /whatsapp_logs/{logId} {
      allow read, write: if isAdmin();
    }

    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
    }

    match /settings/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /automation_rules/{ruleId} {
      allow read, write, delete: if isAdmin();
    }

    match /daily_summaries/{date} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
  }
}
