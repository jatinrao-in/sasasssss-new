rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAdmin() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isGhost() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isGhost', false) == true;
    }

    match /notifications/{uid}/items/{id} {
      allow read: if request.auth.uid == uid;
      allow update, delete: if request.auth.uid == uid && !isGhost();
      allow create: if request.auth != null && !isGhost();
    }

    match /projects/{projectId} {
      allow read: if request.auth != null;
      allow create, delete, update: if isAdmin() && !isGhost();
    }

    match /tasks/{taskId} {
      allow read: if request.auth != null;
      allow create, delete: if isAdmin() && !isGhost();
      allow update: if (isAdmin() && !isGhost()) || (
        request.auth.uid == resource.data.assignedTo && !isGhost() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['completionPercent', 'status', 'updatedAt', 'completedAt'])
      );
    }

    match /expenses/{expenseId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isAdmin() && !isGhost();
    }

    match /enquiries/{enquiryId} {
      allow read: if isAdmin() || request.auth.uid == resource.data.assignedTo;
      allow create, delete: if isAdmin() && !isGhost();
      allow update: if (isAdmin() && !isGhost()) || (
        request.auth.uid == resource.data.assignedTo && !isGhost() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'remarks', 'lastNoteDate', 'updatedAt'])
      );
    }

    match /followups/{followupId} {
      allow read: if isAdmin() || request.auth.uid == resource.data.assignedTo;
      allow create, delete: if isAdmin() && !isGhost();
      allow update: if (isAdmin() && !isGhost()) || (
        request.auth.uid == resource.data.assignedTo && !isGhost() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status', 'outcome', 'closingNote', 'closedAt',
          'nextFollowupDate', 'rescheduleCount', 'rescheduleReason',
          'remarks', 'lastNoteDate', 'lastNoteBy', 'updatedAt'
        ])
      );
    }

    match /tools/{toolId} {
      allow read: if isAdmin() || request.auth.uid == resource.data.assignedTo;
      allow create, update, delete: if isAdmin() && !isGhost();
    }

    match /salary/{uid}/months/{monthId} {
      allow read: if isAdmin() || request.auth.uid == uid;
      allow create, update, delete: if isAdmin() && !isGhost();
    }

    match /users/{userId} {
      allow read: if isAdmin() || request.auth.uid == userId;
      allow create, update, delete: if isAdmin() && !isGhost();
    }

    match /blacklisted_emails/{email} {
      allow read: if isAdmin();
      allow write: if isAdmin() && !isGhost();
    }

    match /{document=**} {
      allow read: if request.auth != null;
      allow write: if isAdmin() && !isGhost(); // Default fallback: admins can write anything, others only read
    }
  }
}
