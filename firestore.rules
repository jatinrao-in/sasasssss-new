rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /notifications/{uid}/items/{id} {
      allow read, update, delete: if request.auth.uid == uid;
      allow create: if request.auth != null;
    }

    match /projects/{projectId} {
      allow read: if request.auth != null;
      allow create, delete: if isAdmin();
      allow update: if isAdmin();
    }

    match /tasks/{taskId} {
      allow read: if request.auth != null;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (
        request.auth.uid == resource.data.assignedTo && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['completionPercent', 'status', 'updatedAt', 'completedAt'])
      );
    }

    match /expenses/{expenseId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isAdmin();
    }

    match /enquiries/{enquiryId} {
      allow read: if isAdmin() || request.auth.uid == resource.data.assignedTo;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (
        request.auth.uid == resource.data.assignedTo &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'remarks', 'lastNoteDate', 'updatedAt'])
      );
    }

    match /{document=**} {
      allow read: if request.auth != null;
      allow write: if isAdmin(); // Default fallback: admins can write anything, others only read
    }
  }
}
